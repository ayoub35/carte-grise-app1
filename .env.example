# AutoDossiers - Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL Database (Neon or standard PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Session secret (generate a random string, e.g. openssl rand -hex 32)
SESSION_SECRET=your-session-secret-change-me

# Stripe API Keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Application URL (used for Stripe redirect URLs)
APP_BASE_URL=http://localhost:5000

# Server port
PORT=5000
